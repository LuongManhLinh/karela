  {
    "type": "CompositeElement",
    "element_id": "1eefb9222776a480256f4a27a9c9547a",
    "text": "5. C\u00e0i \u0111\u1eb7t b\u1eb1ng Python\n\nV\u00ed d\u1ee5 sau v\u1ec1 vi\u1ec7c c\u00e0i \u0111\u1eb7t A2PMF theo Grayscale\n\n@staticmethod def adaptive_two_pass_median_\ufb01lter( image, w1, w2, a=1, b=1, pepper_threshold=20, salt_threshold=235 ): # Step 1 # Because the image is RGB, we need to convert it to grayscale\n\nX_grayscale = FilterGrayscale.rgb_to_grayscale(image) # Apply median \ufb01lter to the grayscale image Y = FilterGrayscale.median_\ufb01lter(image, w1) # Calculate the error index matrix by grayscale between X and Y Y_grayscale = FilterGrayscale.rgb_to_grayscale(Y) E1 = FilterUtils.omega(X_grayscale - Y_grayscale) # Step 2 Y_tilde = FilterGrayscale.__psi( image, Y, X_grayscale, Y_grayscale, E1, a, b, pepper_threshold, salt_threshold ) # Calculate the error index matrix by grayscale between Y and Y_tilde Y_tilde_grayscale = FilterGrayscale.rgb_to_grayscale(Y_tilde) E2 = FilterUtils.omega(Y_grayscale - Y_tilde_grayscale) # Step 3 Z = np.copy(image) indices = np.argwhere(E2 == 0) # Pad Y_tilde_grayscale to use in the \ufb01nd median step Y_tilde_grayscale_padded = np.pad( Y_tilde_grayscale, pad_width=w2 // 2, mode='edge') # Find the median value when E2 is zero for idx in indices: i, j = idx[0], idx[1] row_idx, col_idx = FilterGrayscale.__get_median_position( Y_tilde_grayscale_padded, w2, (i, j) ) Z[i, j] = Y_tilde[row_idx, col_idx] return Z\n\nNgo\u00e0i ra c\u00f2n c\u00f3 c\u00e1c \ufb01le trong source code:\n\n\u25cf \ufb01lter.py: g\u1ed3m FilterGrayscale v\u00e0 FilterRGB c\u00e0i \u0111\u1eb7t thu\u1eadt to\u00e1n \u0111\u00e3 s\u1eeda \u0111\u1ed5i, l\u1ecdc theo Grayscale ho\u1eb7c l\u1ecdc theo RGB",
    "metadata": {
